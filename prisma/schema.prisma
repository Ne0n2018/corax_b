// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())

  email       String @unique
  password    String
  displayName String

  role UserRole @default(REGULAR)

  isVerified         Boolean @default(false) @map("is_verified")
  isTwoFactorEnabled Boolean @default(false) @map("is_two_factor_enabled")

  metod AuthMetod

  accounts Account[]
  Cart     Cart?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id String @id @default(uuid())

  type              String
  provider          String
  providerAccountId String? @map("provider_account_id")

  refreshToken String? @map("refresh_token")
  accessToken  String? @map("access_token")
  expiresAt    Int     @map("expires_at")

  user   User?   @relation(fields: [userId], references: [id])
  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("accounts")
}

model Token {
  id String @id @default(uuid())

  email     String
  token     String    @unique
  type      EnumToken
  experesIn DateTime  @map("experes_in")

  @@map("tokens")
}

model Category {
  id          String        @id @default(uuid())
  name        String
  SubCategory SubCategory[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("categorys")
}

model SubCategory {
  id   String @id @default(uuid())
  name String

  catagory   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String    @map("category_id")
  Product    Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Provider {
  id          String    @id @default(uuid())
  name        String
  imageUrl    String    @map("image_url")
  description String
  products    Product[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
}

model Product {
  id               String                  @id @default(uuid())
  name             String
  imageUrl         String                  @map("image_url")
  shortDescription String                  @map("short_description")
  description      String
  advantages       String
  structure        String
  formRelease      String                  @map("form_release")
  defaultPrice     Float                   @map("default_price")
  subCategory      SubCategory             @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  subCategoryId    String                  @map("sub_category_id")
  Provider         Provider                @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId       String                  @map("provider_id")
  characteristic   ProductCharacteristic[]
  Taste            Taste[]
  Size             Size[]

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  ProductItem ProductItem[]

  @@map("products")
}

model ProductCharacteristic {
  id        String  @id @default(uuid())
  name      String
  value     String
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updateAt  DateTime @updatedAt @map("updated_at")

  @@unique([name, productId])
  @@map("product_characteristic")
}

model Taste {
  id    String @id @default(uuid())
  name  String
  price Float

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tastes")
}

model Size {
  id    String @id @default(uuid())
  name  String
  price Float

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model ProductItem {
  id String @id @default(uuid())

  price     Float
  taste     String
  size      String
  CartItem  CartItem[]
  product   Product    @relation(fields: [productId], references: [id])
  productId String    @map("product_id")
  createdAt DateTime  @default(now()) @map("created_At")
  updatedAt DateTime  @updatedAt @map("updatetd_At")

  @@unique([productId, taste, size])
  @@map("product_item")
}

model CartItem {
  id String @id @default(uuid())

  quantity Int @default(1)

  productItem   ProductItem @relation(fields: [productItemId], references: [id], onDelete: Cascade)
  productItemId String      @map("product_item_id")
  cart          Cart        @relation(fields: [cartId], references: [id])
  cartId        String      @map("cart_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([productItemId, cartId])
  @@map("cart_item")
}

model Cart {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  CartItem CartItem[]

  totalAmount Float @map("total_amount")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId])
}

enum UserRole {
  REGULAR
  ADMIN
  SPORTS
}

enum AuthMetod {
  CREDENTIALS
  GOOGLE
  YANDEX
}

enum EnumToken {
  VERIFICATION
  TWO_FACTOR
  PASSWORD_RESET
}
